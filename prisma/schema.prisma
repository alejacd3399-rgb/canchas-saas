generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum LicenseStatus {
  active
  expired
  cancelled
}

enum TenantUserRole {
  owner
  staff
}

enum FieldType {
  futbol5
  futbol7
  futbol11
}

enum FieldSurface {
  synthetic
  natural
  hybrid
}

enum PaymentStatus {
  paid
  partial
  unpaid
}

enum ReservationStatus {
  confirmed
  cancelled
  completed
}

enum PaymentMethod {
  cash
  nequi
  transfer
  other
}

// ─── TABLAS DE PLATAFORMA ─────────────────────────────────────────────────────

model Tenant {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  businessName  String    @map("business_name") @db.VarChar(255)
  slug          String    @unique @db.VarChar(100)
  nit           String?   @db.VarChar(20)
  phone         String?   @db.VarChar(20)
  email         String?   @db.VarChar(255)
  address       String?
  logoUrl       String?   @map("logo_url") @db.VarChar(500)
  timezone      String    @default("America/Bogota") @db.VarChar(50)
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz()

  licenses      License[]
  tenantUsers   TenantUser[]
  fields        Field[]
  customers     Customer[]
  loyaltyConfig LoyaltyConfig?
  reservations  Reservation[]
  payments      Payment[]

  @@map("tenants")
}

model License {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String        @map("tenant_id") @db.Uuid
  planName          String        @map("plan_name") @db.VarChar(100)
  price             Decimal       @db.Decimal(10, 2)
  startsAt          DateTime      @map("starts_at") @db.Date
  expiresAt         DateTime      @map("expires_at") @db.Date
  status            LicenseStatus @default(active)
  paymentReference  String?       @map("payment_reference") @db.VarChar(255)
  notes             String?
  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt         DateTime      @updatedAt @map("updated_at") @db.Timestamptz()

  tenant            Tenant        @relation(fields: [tenantId], references: [id])

  @@map("licenses")
}

// ─── TABLAS DE DOMINIO ────────────────────────────────────────────────────────

model TenantUser {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String         @map("tenant_id") @db.Uuid
  stackAuthId  String         @unique @map("stack_auth_id") @db.VarChar(255)
  email        String         @db.VarChar(255)
  fullName     String         @map("full_name") @db.VarChar(255)
  role         TenantUserRole @default(staff)
  isActive     Boolean        @default(true) @map("is_active")
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime       @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt    DateTime?      @map("deleted_at") @db.Timestamptz()

  tenant       Tenant         @relation(fields: [tenantId], references: [id])
  reservations Reservation[]
  payments     Payment[]

  @@map("tenant_users")
}

model Field {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String       @map("tenant_id") @db.Uuid
  name         String       @db.VarChar(150)
  fieldType    FieldType    @map("field_type")
  pricePerHour Decimal      @map("price_per_hour") @db.Decimal(10, 2)
  surface      FieldSurface @default(synthetic)
  isActive     Boolean      @default(true) @map("is_active")
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime     @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt    DateTime?    @map("deleted_at") @db.Timestamptz()

  tenant       Tenant         @relation(fields: [tenantId], references: [id])
  schedules    FieldSchedule[]
  reservations Reservation[]

  @@map("fields")
}

model FieldSchedule {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fieldId             String   @map("field_id") @db.Uuid
  tenantId            String   @map("tenant_id") @db.Uuid
  dayOfWeek           Int      @map("day_of_week") @db.SmallInt
  openTime            String   @map("open_time")
  closeTime           String   @map("close_time")
  slotDurationMinutes Int      @default(60) @map("slot_duration_minutes") @db.SmallInt
  isActive            Boolean  @default(true) @map("is_active")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  field               Field    @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@map("field_schedules")
}

model Customer {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String        @map("tenant_id") @db.Uuid
  phone             String        @db.VarChar(20)
  fullName          String        @map("full_name") @db.VarChar(255)
  email             String?       @db.VarChar(255)
  notes             String?
  reservationsCount Int           @default(0) @map("reservations_count")
  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt         DateTime      @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt         DateTime?     @map("deleted_at") @db.Timestamptz()

  tenant            Tenant        @relation(fields: [tenantId], references: [id])
  reservations      Reservation[]

  @@unique([tenantId, phone])
  @@map("customers")
}

model LoyaltyConfig {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId              String   @unique @map("tenant_id") @db.Uuid
  reservationsForReward Int      @default(5) @map("reservations_for_reward") @db.SmallInt
  rewardDescription     String   @map("reward_description")
  isActive              Boolean  @default(true) @map("is_active")
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt             DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  tenant                Tenant   @relation(fields: [tenantId], references: [id])

  @@map("loyalty_configs")
}

model Reservation {
  id                 String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String            @map("tenant_id") @db.Uuid
  fieldId            String            @map("field_id") @db.Uuid
  customerId         String            @map("customer_id") @db.Uuid
  createdBy          String            @map("created_by") @db.Uuid
  reservationDate    DateTime          @map("reservation_date") @db.Date
  startTime          String            @map("start_time")
  endTime            String            @map("end_time")
  durationMinutes    Int               @map("duration_minutes") @db.SmallInt
  totalAmount        Decimal           @map("total_amount") @db.Decimal(10, 2)
  paidAmount         Decimal           @default(0) @map("paid_amount") @db.Decimal(10, 2)
  paymentStatus      PaymentStatus     @default(unpaid) @map("payment_status")
  status             ReservationStatus @default(confirmed)
  notes              String?
  cancellationReason String?           @map("cancellation_reason")
  createdAt          DateTime          @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt          DateTime          @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt          DateTime?         @map("deleted_at") @db.Timestamptz()

  tenant             Tenant            @relation(fields: [tenantId], references: [id])
  field              Field             @relation(fields: [fieldId], references: [id])
  customer           Customer          @relation(fields: [customerId], references: [id])
  createdByUser      TenantUser        @relation(fields: [createdBy], references: [id])
  payments           Payment[]

  @@map("reservations")
}

model Payment {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String        @map("tenant_id") @db.Uuid
  reservationId String        @map("reservation_id") @db.Uuid
  receivedBy    String        @map("received_by") @db.Uuid
  amount        Decimal       @db.Decimal(10, 2)
  paymentMethod PaymentMethod @default(cash) @map("payment_method")
  reference     String?       @db.VarChar(255)
  notes         String?
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz()

  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  reservation   Reservation   @relation(fields: [reservationId], references: [id])
  receivedByUser TenantUser   @relation(fields: [receivedBy], references: [id])

  @@map("payments")
}